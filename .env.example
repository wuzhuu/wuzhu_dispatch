# ── Environment ─────────────────────────────────────────────────────
# Set to "production" to enable secret validation and safety checks
# ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────
# Set DATABASE_URL to use SQLite (testing) or custom URL.
# If empty, falls back to mysql_* fields.
# DATABASE_URL=sqlite+aiosqlite:///test.db
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=wuzhu_dispatch

# ── Master secrets ──────────────────────────────────────────────────
DISPATCH_SERVER_SECRET=change-this-to-a-strong-random-secret
REGISTRATION_TOKEN=change-this-registration-token
SESSION_SECRET=change-this-session-secret

# ── CORS / CSRF origins (comma-separated URLs) ──────────────────────
# CORS_ALLOWED_ORIGINS=https://admin.dispatch.example.com,https://dispatch.example.com
# CSRF_ALLOWED_ORIGINS=https://admin.dispatch.example.com

# ── Optional overrides ──────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# NODE_OFFLINE_SECONDS=60
# TASK_LEASE_SECONDS=300
# MAX_LEASE_SECONDS=3600
